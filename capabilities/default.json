{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "guide"],
  "remote": {
    "urls": [
      "http://127.0.0.1/*",
      "http://localhost/*",
      "http://192.168.99.47/*",
      "http://192.168.0.101/*"
    ]
  },
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-outer-position",
    "shell:allow-open",
    "dialog:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister"
  ]
}
