{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Floating Lyrics",
  "identifier": "com.necra.floatinglyrics.standalone",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "./html"
  },
  "app": {
    "windows": [
      {
        "title": "Floating Lyrics",
        "create": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": false,
        "resizable": false,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "copyright": "Copyright (c) 2026 necra",
    "publisher": "necra",
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsi"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "floatinglyricsst"
        ]
      }
    }
  }
}
